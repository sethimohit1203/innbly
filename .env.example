# --- Server-side only (never exposed to the browser) ---
# See google-apps-script/README.md for how to get these.
SHEETS_WEBAPP_URL=
ADMIN_SHEETS_KEY=
ADMIN_PASSCODE=
ADMIN_SESSION_SECRET=

# Razorpay test-mode keys (optional) — https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# --- Client-side (safe to expose — OAuth client IDs are public by design) ---
# Create one for free at https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_CLIENT_ID=

# Supabase project — anon/public key is safe to expose client-side by design
# (row-level security policies enforce access, not secrecy of this key).
# https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
