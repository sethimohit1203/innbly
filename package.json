{
  "name": "innbly",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n client,api -c blue,green \"npm:dev:client\" \"npm:dev:api\"",
    "dev:client": "vite",
    "dev:api": "tsx watch scripts/dev-api-server.ts",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck:api": "tsc --noEmit -p api/tsconfig.json",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@supabase/supabase-js": "^2.110.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.42.2",
    "libphonenumber-js": "^1.13.9",
    "lucide-react": "^0.446.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.82.0",
    "react-router-dom": "^6.26.2",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "@types/react": "^18.3.10",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "concurrently": "^10.0.3",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "tsx": "^4.23.1",
    "typescript": "^5.6.2",
    "vite": "^5.4.8"
  }
}
